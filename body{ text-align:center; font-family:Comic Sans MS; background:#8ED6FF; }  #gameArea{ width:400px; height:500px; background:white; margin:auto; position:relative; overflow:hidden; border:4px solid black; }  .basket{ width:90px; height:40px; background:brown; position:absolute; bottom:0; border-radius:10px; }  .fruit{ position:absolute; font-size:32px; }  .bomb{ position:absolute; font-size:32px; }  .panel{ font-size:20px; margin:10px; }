body{
text-align:center;
font-family:Comic Sans MS;
background:#8ED6FF;
}

#gameArea{
width:400px;
height:500px;
background:white;
margin:auto;
position:relative;
overflow:hidden;
border:4px solid black;
}

.basket{
width:90px;
height:40px;
background:brown;
position:absolute;
bottom:0;
border-radius:10px;
}

.fruit{
position:absolute;
font-size:32px;
}

.bomb{
position:absolute;
font-size:32px;
}

.panel{
font-size:20px;
margin:10px;
}
